<body>
    <div class="container">
        <h1>Password Strength Checker</h1>
        <input type="password" id="passwordInput" placeholder="Enter your password">
        <button onclick="checkPassword()">Check Strength</button>
        <div id="result">
            <div class="score-label" id="scoreLabel"></div>
            <div id="strengthText"></div>
            <div class="details" id="details"></div>
        </div>
    </div>

    <script>
        function checkPassword() {
            const password = document.getElementById('passwordInput').value;
            const resultDiv = document.getElementById('result');
            const scoreLabel = document.getElementById('scoreLabel');
            const strengthText = document.getElementById('strengthText');
            const detailsDiv = document.getElementById('details');
            
            if (!password) {
                alert('Please enter a password');
                return;
            }

            let score = 0;
            const checks = [];

            if (password.length >= 8) score += 10;
            if (password.length >= 12) score += 10;
            if (password.length >= 16) score += 5;
            if (/[a-z]/.test(password)) { score += 10; checks.push('✓ Lowercase letters'); }
            if (/[A-Z]/.test(password)) { score += 15; checks.push('✓ Uppercase letters'); }
            if (/[0-9]/.test(password)) { score += 15; checks.push('✓ Numbers'); }
            if (/[^a-zA-Z0-9]/.test(password)) { score += 20; checks.push('✓ Special characters'); }
            if (!/(.)\1{2,}/.test(password)) { score += 10; checks.push('✓ No repeating characters'); }
            if (!/^[a-zA-Z]+$/.test(password) && !/^[0-9]+$/.test(password)) { score += 5; checks.push('✓ Mixed character types'); }

            const commonPasswords = ['password', '123456', 'qwerty', 'abc123', 'letmein', 'welcome', 'admin', 'login'];
            if (!commonPasswords.includes(password.toLowerCase())) { score += 10; checks.push('✓ Not a common password'); }

            score = Math.min(100, score);

            let color, strength;
            if (score < 30) { color = '#dc3545'; strength = 'Very Weak'; }
            else if (score < 50) { color = '#fd7e14'; strength = 'Weak'; }
            else if (score < 70) { color = '#ffc107'; strength = 'Fair'; }
            else if (score < 85) { color = '#28a745'; strength = 'Strong'; }
            else { color = '#198754'; strength = 'Very Strong'; }

            resultDiv.style.display = 'block';
            resultDiv.style.background = color + '20';
            resultDiv.style.border = `2px solid ${color}`;
            scoreLabel.textContent = score + '/100';
            scoreLabel.style.color = color;
            strengthText.textContent = strength;
            strengthText.style.color = color;
            detailsDiv.innerHTML = checks.length ? '<strong>Criteria met:</strong><br>' + checks.join('<br>') : '';
        }
    </script>
</body>
</html>
